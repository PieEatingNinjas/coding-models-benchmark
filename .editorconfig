# EditorConfig — shared conventions so every model is held to the same bar.
# Kept conservative on purpose: style rules are suggestions, not build errors,
# so the baseline stays green under `dotnet format --verify-no-changes`.
root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{cs,csx}]
indent_size = 4
# Modern C#
csharp_style_namespace_declarations = file_scoped:suggestion
csharp_prefer_braces = true:suggestion
csharp_style_var_for_built_in_types = false:silent
# Usings
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
# Quality
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion

[*.{json,yml,yaml,csproj,props,targets}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
